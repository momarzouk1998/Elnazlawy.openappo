# ============================================
# Supabase (Database + Auth + Storage)
# ============================================
# احصل على القيم دي من Supabase Dashboard → Settings → API
# راجع SETUP_AR.md "الخطوة 2: نسخ المفاتيح" للتفاصيل

# Project URL (شكله: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# anon public key (المفتاح الطويل اللي بيبدأ بـ eyJ...) — آمن للـ frontend
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# service_role key (اضغط "Reveal" في Supabase Dashboard لإظهاره)
# ⚠️ سري جداً — بيدي صلاحية كاملة لكل البيانات. لا تنشره على GitHub!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key
